{
  "manifest_version": 3,
  
  "name": "Dictionnello",
  "version": "1.0.0",
  "description": "Votre extension qui cherche une définition en 1 clic.",
  
  "browser_specific_settings": {
    "gecko": {
      "id": "dictionnaire-fr@example.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  
  "icons": {
    "128": "images/iconDictionnello.png"
  },
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "Dictionnello"
  },
  
  "permissions": [
    "storage"
  ],
  
  "host_permissions": [
    "https://fr.wiktionary.org/*"
  ]
}