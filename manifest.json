{
  "manifest_version": 3,
  
  "name": "Dictionnaire Français",
  "version": "1.0.0",
  "description": "Définitions instantanées de mots français",
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "Dictionnaire Français"
  },
  
  "permissions": [
    "storage"
  ],
  
  "host_permissions": [
    "https://fr.wiktionary.org/*"
  ]
}